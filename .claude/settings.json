{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "./ai/hooks/post_edit_format.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "./ai/hooks/pre_tool_guard.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "./ai/hooks/session_context.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  }
}
